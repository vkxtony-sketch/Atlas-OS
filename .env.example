# =============================================================================
# Atlas OS - Example Environment Configuration
# Copy to ``.env`` and adjust. Every value here is also exposed via
# ``core.config.AtlasSettings``.
# =============================================================================

# ---- LLM provider selection ------------------------------------------------
# One of: mock (default, offline), template (offline, structured), http (POST),
#         echo (tests only).
ATLAS_LLM_PROVIDER=mock

# Only used when ATLAS_LLM_PROVIDER=http
ATLAS_LLM_HTTP_URL=
ATLAS_LLM_HTTP_MODEL=atlas-local
ATLAS_LLM_HTTP_TOKEN=
ATLAS_LLM_HTTP_TIMEOUT=30

# ---- Orchestrator tuning ----------------------------------------------------
ATLAS_CONSENSUS_PASSES=1
ATLAS_REVIEW_TARGET_SCORE=70
ATLAS_AUTONOMOUS_INTERVAL=5
ATLAS_AUTONOMOUS_MAX_CYCLES=10

# ---- Web tool ---------------------------------------------------------------
ATLAS_WEB_TOOL_MODE=mock
ATLAS_WEB_SEARCH_ENDPOINT=

# ---- FastAPI server ---------------------------------------------------------
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000

# ---- Permissions + audit ----------------------------------------------------
# Choose ONE of the three patterns to control side-effects.
# (1) auto-deny:    ATLAS_AUTO_DENY=true
# (2) auto-approve: ATLAS_AUTO_APPROVE=true            (dev convenience)
# (3) selective:    ATLAS_ALLOW_GIT_PUSH=true etc.
ATLAS_AUTO_DENY=false
ATLAS_AUTO_APPROVE=false
ATLAS_ALLOW_GIT_PUSH=false
ATLAS_ALLOW_GIT_COMMIT=false
ATLAS_ALLOW_DEPLOY_RUN=false
ATLAS_ALLOW_FILE_MKDIR=false
ATLAS_ALLOW_FILE_WRITE=false

# Comma-separated list of actions that REQUIRE permission to run.
ATLAS_REQUIRE_PERMISSION_FOR=git.commit,git.push,deploy.run,terminal.run

# Where the append-only audit log lives.
ATLAS_AUDIT_LOG_PATH=atlas_audit.log

# ---- Optional encryption at rest -------------------------------------------
ATLAS_ENABLE_ENCRYPTED_MEMORY=false
ATLAS_MEMORY_PASSPHRASE=

# ---- Code execution (DANGEROUS) --------------------------------------------
# Setting this to true by itself does NOT enable exec(); a real sandbox
# must be wired in via core/security/sandbox.py (out of scope for this build).
ATLAS_ALLOW_CODE_EXECUTION=false

# ---- Memory + knowledge paths ----------------------------------------------
ATLAS_MEMORY_PATH=atlas_memory.json
ATLAS_SHARED_MEMORY_PATH=atlas_shared_memory.json
ATLAS_KNOWLEDGE_PATH=atlas_knowledge

# ---- Plugins ----------------------------------------------------------------
# Comma-separated search paths for plugin manifests (plugin.toml/plugin.json).
ATLAS_PLUGIN_DIRS=plugins
ATLAS_HOT_RELOAD_PLUGINS=false

# ---- Subprocess allow-list (integration hub) -------------------------------
# Bins added here complement the built-in allow-list (gh, git, docker, code, ...).
ATLAS_ALLOW_BIN=
